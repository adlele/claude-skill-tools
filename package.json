{
  "name": "@adlele/claude-skill-tools",
  "version": "0.1.0",
  "description": "A collection of AI development tools, primarily built with Claude Code CLI in mind",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "composer": "./dist/bin/composer.js",
    "sandbox": "./dist/bin/sandbox.js",
    "session-explorer": "./dist/bin/session-explorer.js",
    "session-analyzer": "./dist/bin/session-analyzer.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "hooks/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}